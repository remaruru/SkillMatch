# Database - provided by Railway MySQL plugin (copy from Railway dashboard)
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/railway"

# JWT Secret - generate a strong random secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Google Gemini AI API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Frontend URL - set to your Railway frontend service URL after deployment
# e.g. https://skillmatch-frontend.up.railway.app
FRONTEND_URL="https://your-frontend.up.railway.app"
