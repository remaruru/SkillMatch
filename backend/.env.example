# Database - provided by Render PostgreSQL (copy from Render dashboard)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# JWT Secret - generate a strong random secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Google Gemini AI API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Frontend URL - set to your Render frontend static site URL after deployment
# e.g. https://skillmatch-frontend.onrender.com
FRONTEND_URL="https://your-frontend.onrender.com"
